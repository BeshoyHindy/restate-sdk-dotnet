<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <RootNamespace>Restate.Sdk</RootNamespace>
        <AssemblyName>Restate.Sdk</AssemblyName>
        <GenerateDocumentationFile>true</GenerateDocumentationFile>
        <IsPackable>true</IsPackable>
        <IsAotCompatible>true</IsAotCompatible>
        <IsTrimmable>true</IsTrimmable>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    </PropertyGroup>

    <!-- Bundle the source generator into this package's analyzers folder -->
    <PropertyGroup>
        <TargetsForTfmSpecificContentInPackage>
            $(TargetsForTfmSpecificContentInPackage);_IncludeGeneratorInPackage
        </TargetsForTfmSpecificContentInPackage>
    </PropertyGroup>

    <ItemGroup>
        <None Include="../../README.md" Pack="true" PackagePath="/"/>
    </ItemGroup>

    <ItemGroup>
        <FrameworkReference Include="Microsoft.AspNetCore.App"/>
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Google.Protobuf"/>
        <PackageReference Include="Grpc.Tools" PrivateAssets="All"/>
    </ItemGroup>

    <!--
        Protocol buffers are generated from the pinned `sdk-shared-core` submodule so the wire
        types stay byte-for-byte synchronized with the released Restate service protocol.
        The upstream proto carries no `csharp_namespace`, so we inject it into a build-local copy
        (under obj/) rather than editing the vendored submodule file. Bump the submodule pin to
        adopt a newer protocol version — no manual proto edits required.
    -->
    <PropertyGroup>
        <RestateSharedCoreProto>$(MSBuildThisFileDirectory)../../third_party/sdk-shared-core/service-protocol/dev/restate/service/protocol.proto</RestateSharedCoreProto>
        <RestateSyncedProtoRoot>$(MSBuildProjectDirectory)/obj/restate-proto</RestateSyncedProtoRoot>
        <RestateSyncedProto>$(RestateSyncedProtoRoot)/dev/restate/service/protocol.proto</RestateSyncedProto>
        <RestateProtoNamespace>Restate.Sdk.Internal.Protocol.Generated</RestateProtoNamespace>
    </PropertyGroup>

    <UsingTask TaskName="InjectCSharpNamespace" TaskFactory="RoslynCodeTaskFactory"
               AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">
        <ParameterGroup>
            <Source ParameterType="System.String" Required="true"/>
            <Destination ParameterType="System.String" Required="true"/>
            <Namespace ParameterType="System.String" Required="true"/>
        </ParameterGroup>
        <Task>
            <Code Type="Fragment" Language="cs"><![CDATA[
                var text = System.IO.File.ReadAllText(Source);
                if (!text.Contains("csharp_namespace"))
                {
                    const string marker = "option go_package";
                    var idx = text.IndexOf(marker, System.StringComparison.Ordinal);
                    var eol = text.IndexOf('\n', idx);
                    var option = "option csharp_namespace = \"" + Namespace + "\";\n";
                    text = text.Substring(0, eol + 1) + option + text.Substring(eol + 1);
                }
                System.IO.Directory.CreateDirectory(System.IO.Path.GetDirectoryName(Destination));
                System.IO.File.WriteAllText(Destination, text);
            ]]></Code>
        </Task>
    </UsingTask>

    <Target Name="SyncRestateProto"
            BeforeTargets="Protobuf_BeforeCompile;CollectProtobufReferences;CoreCompile"
            Inputs="$(RestateSharedCoreProto)"
            Outputs="$(RestateSyncedProto)">
        <Error Condition="!Exists('$(RestateSharedCoreProto)')"
               Text="shared-core submodule proto not found at '$(RestateSharedCoreProto)'. Run: git submodule update --init --recursive"/>
        <InjectCSharpNamespace Source="$(RestateSharedCoreProto)"
                               Destination="$(RestateSyncedProto)"
                               Namespace="$(RestateProtoNamespace)"/>
    </Target>

    <ItemGroup>
        <Protobuf Include="$(RestateSyncedProto)"
                  GrpcServices="None"
                  ProtoRoot="$(RestateSyncedProtoRoot)"/>
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="../Restate.Sdk.Generators/Restate.Sdk.Generators.csproj"
                          OutputItemType="Analyzer"
                          ReferenceOutputAssembly="false"
                          PrivateAssets="all"/>
    </ItemGroup>

    <ItemGroup>
        <InternalsVisibleTo Include="Restate.Sdk.Lambda"/>
        <InternalsVisibleTo Include="Restate.Sdk.Tests"/>
        <InternalsVisibleTo Include="Restate.Sdk.Testing"/>
        <InternalsVisibleTo Include="Restate.Sdk.Benchmarks"/>
    </ItemGroup>

    <!-- Resolve the source generator DLL and include it in the nupkg at analyzers/dotnet/cs -->
    <Target Name="_IncludeGeneratorInPackage">
        <MSBuild Projects="../Restate.Sdk.Generators/Restate.Sdk.Generators.csproj"
                 Targets="GetTargetPath"
                 Properties="TargetFramework=netstandard2.0">
            <Output TaskParameter="TargetOutputs" ItemName="_GeneratorTargetPath"/>
        </MSBuild>
        <ItemGroup>
            <TfmSpecificPackageFile Include="@(_GeneratorTargetPath)"
                                    PackagePath="analyzers/dotnet/cs"/>
        </ItemGroup>
    </Target>

</Project>
