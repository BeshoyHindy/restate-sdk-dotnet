{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "src": "../src",
          "files": [
            "Restate.Sdk/Restate.Sdk.csproj",
            "Restate.Sdk.Testing/Restate.Sdk.Testing.csproj",
            "Restate.Sdk.Lambda/Restate.Sdk.Lambda.csproj"
          ]
        }
      ],
      "dest": "api",
      "properties": {
        "TargetFramework": "net10.0"
      }
    }
  ],
  "build": {
    "content": [
      {
        "files": ["**/*.{md,yml}"],
        "exclude": ["_site/**"]
      }
    ],
    "output": "_site",
    "template": ["default", "modern"],
    "globalMetadata": {
      "_appName": "Restate .NET SDK",
      "_appTitle": "Restate .NET SDK",
      "_appFooter": "Community .NET SDK for Restate. Not an official Restate SDK.",
      "_enableSearch": true,
      "pdf": false
    }
  }
}
